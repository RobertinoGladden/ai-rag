# === LLM ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile  # or mixtral-8x7b-32768

# === Embeddings ===
EMBEDDING_MODEL=all-MiniLM-L6-v2    # local, no API needed
EMBEDDING_DEVICE=cpu                 # atau cuda jika ada GPU

# === Vector Store ===
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=rag_documents

# === RAG Settings ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
MAX_TOKENS=2048
TEMPERATURE=0.1

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# === MLflow ===
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=rag_pipeline

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
